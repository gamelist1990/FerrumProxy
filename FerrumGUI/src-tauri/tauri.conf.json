{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FerrumProxy Client",
  "version": "0.1.0",
  "identifier": "com.ferrumproxy.client",
  "build": {
    "beforeBuildCommand": "bun run build:client-frontend",
    "beforeDevCommand": "bun run dev:frontend",
    "frontendDist": "../public",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "FerrumProxy Client",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
