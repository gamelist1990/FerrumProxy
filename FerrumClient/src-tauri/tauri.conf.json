{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FerrumProxy Client",
  "version": "0.1.0",
  "identifier": "com.ferrumproxy.client",
  "build": {
    "beforeBuildCommand": "bun run build:frontend",
    "beforeDevCommand": "bun run dev:frontend",
    "frontendDist": "../public",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "FerrumProxy Client",
        "width": 820,
        "height": 520,
        "minWidth": 560,
        "minHeight": 360,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
